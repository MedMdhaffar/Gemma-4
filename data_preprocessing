{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":2632847,"datasetId":1589971,"databundleVersionId":2676713}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import json\nimport numpy as np\nfrom collections import defaultdict\n\n# ---- CONFIG ----\nJSON_PATH = \"/kaggle/input/datasets/risangbaskoro/wlasl-processed/WLASL_v0.3.json\"\nOUTPUT_PATH = \"/kaggle/working/balanced_video_map.json\"\nSPLIT = \"train\"\n\nBASE_FRAMES = 12        # reference density\nWINDOW_RATIO = 0.6      # % of video used (middle focus)\nMIN_FRAMES = 4\nMAX_FRAMES = 40\n\n# ---- LOAD ----\nwith open(JSON_PATH, \"r\") as f:\n    data = json.load(f)\n\n# ---- COUNT VIDEOS PER CLASS ----\nclass_counts = defaultdict(int)\n\nfor entry in data:\n    gloss = entry[\"gloss\"]\n    for inst in entry[\"instances\"]:\n        if inst[\"split\"] == SPLIT:\n            class_counts[gloss] += 1\n\ncounts = np.array(list(class_counts.values()))\n\n# Robust target (avoid extreme classes)\ntarget_frames_per_class = int(np.percentile(counts, 75) * BASE_FRAMES)\n\nprint(f\"Target frames/class ≈ {target_frames_per_class}\")\n\n# ---- COMPUTE FRAMES PER VIDEO ----\nclass_to_frames = {}\n\nfor gloss, count in class_counts.items():\n    frames = target_frames_per_class / count\n    frames = int(round(frames))\n\n    frames = max(MIN_FRAMES, min(MAX_FRAMES, frames))\n    class_to_frames[gloss] = frames\n\n# ---- FUNCTION: SAMPLE FROM MIDDLE ----\ndef sample_middle_frames(start, end, num_frames):\n    if end == -1 or end <= start:\n        # fallback: assume short clip (~50 frames)\n        start, end = 1, 50\n\n    length = end - start + 1\n    center = (start + end) // 2\n\n    window_size = int(length * WINDOW_RATIO)\n    half = window_size // 2\n\n    new_start = max(start, center - half)\n    new_end = min(end, center + half)\n\n    if new_end <= new_start:\n        new_start, new_end = start, end\n\n    indices = np.linspace(new_start, new_end, num_frames)\n    return indices.astype(int).tolist()\n\n# ---- BUILD OUTPUT ----\nvideo_map = {}\n\nfor entry in data:\n    gloss = entry[\"gloss\"]\n    frames = class_to_frames.get(gloss, BASE_FRAMES)\n\n    for inst in entry[\"instances\"]:\n        if inst[\"split\"] != SPLIT:\n            continue\n\n        vid_id = inst[\"video_id\"]\n        start = inst[\"frame_start\"]\n        end = inst[\"frame_end\"]\n\n        indices = sample_middle_frames(start, end, frames)\n\n        video_map[vid_id] = {\n            \"gloss\": gloss,\n            \"num_frames\": frames,\n            \"frame_indices\": indices,\n            \"bbox\": inst[\"bbox\"]\n        }\n\n# ---- STATS ----\ntotal_frames_per_class = defaultdict(int)\n\nfor vid, info in video_map.items():\n    total_frames_per_class[info[\"gloss\"]] += info[\"num_frames\"]\n\nvalues = list(total_frames_per_class.values())\n\nprint(\"\\n--- Balance stats ---\")\nprint(f\"Classes: {len(values)}\")\nprint(f\"Min total frames/class: {min(values)}\")\nprint(f\"Max total frames/class: {max(values)}\")\nprint(f\"Mean: {np.mean(values):.2f}\")\nprint(f\"Std: {np.std(values):.2f}\")\n\n# ---- SAVE ----\nwith open(OUTPUT_PATH, \"w\") as f:\n    json.dump(video_map, f, indent=2)\n\nprint(f\"\\nSaved → {OUTPUT_PATH}\")","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-04-29T13:51:39.491022Z","iopub.execute_input":"2026-04-29T13:51:39.491263Z","iopub.status.idle":"2026-04-29T13:51:39.916979Z",