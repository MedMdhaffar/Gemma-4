st_ok=True)\n\n    metadata = []\n\n    for vid_id, info in videos:\n        video_path = os.path.join(VIDEO_DIR, f\"{vid_id}.mp4\")\n\n        if not os.path.exists(video_path):\n            continue\n\n        cap = cv2.VideoCapture(video_path)\n        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n\n        if total_frames <= 0:\n            cap.release()\n            continue\n\n        num_frames = info[\"num_frames\"]\n        bbox = info[\"bbox\"]  # [x1, y1, x2, y2]\n\n        indices = get_middle_indices(total_frames, num_frames)\n\n        for i, frame_idx in enumerate(indices):\n            cap.set(cv2.CAP_PROP_POS_FRAMES, int(frame_idx))\n            ret, frame = cap.read()\n\n            if not ret:\n                continue\n\n            h, w, _ = frame.shape\n            x1, y1, x2, y2 = bbox\n\n            # ---- EXPAND BBOX ----\n            x1, y1, x2, y2 = expand_bbox(x1, y1, x2, y2, w, h, PADDING_RATIO)\n\n            # ---- CROP ----\n            crop = frame[y1:y2, x1:x2]\n\n            if crop.size == 0:\n                continue\n\n            # ---- RESIZE CROP ----\n            crop = cv2.resize(crop, (IMG_SIZE, IMG_SIZE))\n\n            img_name = f\"{vid_id}_{i}.jpg\"\n            img_path = os.path.join(class_dir, img_name)\n\n            cv2.imwrite(img_path, crop)\n\n            metadata.append({\n                \"image\": img_name,\n                \"video_id\": vid_id,\n                \"frame_idx\": int(frame_idx),\n                \"bbox\": [x1, y1, x2, y2],   # final used bbox (expanded)\n                \"original_bbox\": bbox\n            })\n\n        cap.release()\n\n    # ---- SAVE METADATA ----\n    with open(os.path.join(class_dir, \"metadata.json\"), \"w\") as f:\n        json.dump(metadata, f, indent=2)\n\nprint(\"\\n✅ Dataset built successfully!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T13:56:57.795316Z","iopub.execute_input":"2026-04-29T13:56:57.795643Z","iopub.status.idle":"