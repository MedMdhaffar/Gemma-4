_ok=True)  # ← ADD THIS\n\nprint(\"✓ Config set\")\nfrom decord import VideoReader, cpu\n\nimport math\n\nclass PositionalEncoding(nn.Module):\n    def __init__(self, d_model, dropout=0.1, max_len=5000):\n        super().__init__()\n        self.dropout = nn.Dropout(p=dropout)\n        pe = torch.zeros(max_len, 1, d_model)\n        position = torch.arange(0, max_len).unsqueeze(1).float()\n        div_term = torch.exp(torch.arange(0, d_model, 2).float() * (-math.log(10000.0) / d_model))\n        pe[:, 0, 0::2] = torch.sin(position * div_term)\n        pe[:, 0, 1::2] = torch.cos(position * div_term)\n        self.register_buffer('pe', pe)\n    def forward(self, x):\n        x = x + self.pe[:x.size(0)]\n        return self.dropout(x)\n\nclass SignLanguageTransformer(nn.Module):\n    def __init__(self, num_classes, d_model=1024, nhead=4, num_layers=2, dropout=0.3):\n        super().__init__()\n        self.pos_encoder = PositionalEncoding(d_model, dropout)\n        encoder_layer = nn.TransformerEncoderLayer(d_model=d_model, nhead=nhead, dropout=dropout)\n        self.transformer_encoder = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)\n        self.classifier = nn.Sequential(nn.Dropout(0.4), nn.Linear(d_model, num_classes))\n\nclass I3DFeatureExtractor(nn.Module):\n    def __init__(self, i3d):\n        super().__init__()\n        self.feature_extractor = i3d\n    def forward(self, x):\n        return self.feature_extractor.extract_features(x)\n\nclass SignLanguageRecognitionModel(nn.Module):\n    def __init__(self, feature_extractor, num_classes):\n        super().__init__()\n        self.feature_extractor = feature_extractor\n        self.transformer = SignLanguageTransformer(num_classes)\n    def forward(self, x):\n        feat = self.feature_extractor(x).squeeze(-1).squeeze(-1)  # (B, 1024, T')\n        feat = feat.permute(2, 0, 1)                               # (T', B, 1024)\n        feat = self.transformer.pos_encoder(feat)\n        out  = self.transformer.transformer_encoder(feat).mean(dim=0)\n        return self.transformer.classifier(out)\n\nprint(\"✓ Model defined\")\n\nimport json, cv2\n\nif os.path.exists(VALID_CACHE):\n    with open(VALID_CACHE) as f:\n        VALID_IDS = set(json.load(f))\n    print(f\"✓ Loaded {len(VALID_IDS)} valid video IDs from cache\")\nelse:\n    print(\"Scanning videos for corruption (one-time ~3 min)...\")\n    with open(NSLT_JSON) as f:\n        data = json.load(f)\n\n    VALID_IDS = set()\n    corrupt = 0\n    for i, vid_id in enumerate(data.keys()):\n        path = os.path.join(VIDEO_DIR, f\"{vid_id}.mp4\")\n        if not os.path.exists(path):\n            continue\n        try:\n            cap = cv2.VideoCapture(path)\n            good_frames = 0\n            bad = False\n            for _ in range(8):\n                ret, frame = cap.read()\n                if not ret:\n                    break\n                if frame is None or frame.shape[0] < 4 or frame.shape[1] < 4:\n                    bad = True\n                    break\n                good_frames += 1\n            cap.release()\n            if good_frames >= 3 and not bad:\n                VALID_IDS.add(vid_id)\n            else:\n                corrupt += 1\n        except:\n            corrupt += 1\n        if (i+1) % 1000 == 0:  \n            print(f\"  {i+1} scanned... {len(VALID_IDS)} valid so far\")\n\n    with open(VALID_CACHE, 'w') as f:\n        json.dump(list(VALID_IDS), f)\n    print(f\"✓ {len(VALID_IDS)} valid  |  {corrupt} corrupt/skipped — saved to cache\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-28T10:22:23.301776Z","iopub.execute_input":"2026-04-28T10:22:23.302495Z","iopub.status.idle":"2026-04-28T10:26:57.417109Z","shell.execute_reply.started":"2026-04-28T10:22:23.302461Z","shell.execute_reply":"2026-04-28T10:26:57.416276Z"}},"outputs":[{"name":"stdout","text":"✓ CUDA: True  GPU: Tesla T4\nCollecting decord\n  Downloading decord-0.6.0-py3-none-manylinux2010_x86_64.whl.metadata (422 bytes)\nRequirement already satisfied: numpy>=1.14.0 in /usr/local/lib/python3.12/dist-packages (from decord) (2.0.2)\nDownloading decord-0.6.0-py3-none-manylinux2010_x86_64.whl (13.6 MB)\n\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m13.6/13.6 MB\u001b[0m \u001b[31m96.2 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m:00:01\u001b[0m:01\u001b[0m\n\u001b[?25hInstalling collected packages: decord\nSuccessfully installed decord-0.6.0\n✓ Config set\n✓ Model defined\nScanning videos for corruption (one-time ~3 min)...\n  1000 scanned... 554 valid so far\n  2000 scanned... 1101 valid so far\n  3000 scanned... 1626 valid so far\n  4000 scanned... 2199 valid so far\n  5000 scanned... 2729 valid so far\n  6000 scanned... 3282 valid so far\n  7000 scanned... 3861 valid so far\n  9000 scanned... 4935 valid so far\n  12000 scanned... 6581 valid so far\n✓ 7232 valid  |  0 corrupt/skipped — saved to cache\n","output_type":"stream"}],"execution_count":1},{"cell_type":"code","source":"\nimport random\nimport numpy as np\nfrom torch.utils.data import Dataset, DataLoader\n\n\ndef preextract_frames(video_dir, valid_ids, frame_size=224, num_frames=64):\n    ids = list(valid_ids)\n    for i, vid_id in enumerate(ids):\n        out_path = f\"{FRAME_CACHE}/{vid_id}.npy\"\n        if os.path.exists(out_path):\n            continue\n        path = os.path.join(video_dir, f\"{vid_id}.mp4\")\n        try:\n            vr = VideoReader(path, ctx=cpu(0), width=frame_size, height=frame_size)\n            n  = len(vr)\n            if n == 0:\n                continue\n            indices = np.linspace(0, n - 1, num_frames).astype(int)\n            frames  = vr.get_batch(indices).asnumpy()   # uint8 → small files\n            np.save(out_path, frames)\n        except Exception as e:\n            print(f\"  skip {vid_id}: {e}\")\n        if (i + 1) % 500 == 0:\n            print(f\"  {i+1}/{len(ids)} extracted...\")\n\nprint(\"Pre-extracting frames (one-time ~10 min)...\")\npreextract_frames(VIDEO_DIR, VALID_IDS, FRAME_SIZE, CLIP_LEN)\nprint(\"✓ Frame extraction done\")\n\n\nclass WLASLDataset(Dataset):\n    def __init__(self, video_dir, nslt_json, valid_ids, split='train',\n                 clip_len=64, frame_size=224, augment=True):\n        self.clip_len   = clip_len\n        self.frame_size = frame_size\n        self.augment    = augment\n\n        with open(nslt_json) as f:\n            data = json.load(f)\n\n        self.samples = []\n        for vid_id, info in data.items():\n            if info['subset'] != split:\n                continue\n            if vid_id not in valid_ids:\n                continue\n            npy_path = f\"{FRAME_CACHE}/{vid_id}.npy\"\n            if os.path.exists(npy_path):                # ← load from .npy now\n                self.samples.append((npy_path, info['action'][0]))\n\n        print(f\"[{split}] {len(self.samples)} samples\")\n\n    def __len__(self):\n        return len(self.samples)\n\n    def _load_clip(self, path):\n        try:\n            frames = np.load(path).astype(np.float32) / 255.0   # (T, H, W, 3)\n\n            if self.augment:\n                if random.random() < 0.8:\n                    frames = np.clip(frames * random.uniform(0.7, 1.3), 0, 1)\n                if random.random() < 0.5:\n                    frames = frames[:, :, ::-1, :].copy()\n\n            frames = (frames - 0.5) / 0.5\n            return torch.from_numpy(frames.transpose(3, 0, 1, 2).astype(np.float32))\n        except Exception:\n            return torch.zeros(3, self.clip_len, self.frame_size, self.frame_size)\n\n    def __getitem__(self, idx):\n        path, label = self.samples[idx]\n        return self._load_clip(path), label\n\n\n\n\nprint(\"✓ Dataset defined\")\n\nimport glob, os\n\nprint(\"=== All .pth files in /kaggle/input ===\")\nfor f in glob.glob('/kaggle/input/**/*.pth', recursive=True):\n    print(f)\n\nprint(\"\\n=== All .pth files in /kaggle/working ===\")\nfor f in glob.glob('/kaggle/working/**/*.pth', recursive=True):\n    print(f)\n\ndevice = torch.device('cuda')\nprint(f\"Using: {torch.cuda.get_device_name(0)}\")\n\ni3d   = InceptionI3d(NUM_CLASSES, in_channels=3)\nfe    = I3DFeatureExtractor(i3d)\nmodel = SignLanguageRecognitionModel(fe, NUM_CLASSES)\n\nstate = torch.load(PRETRAINED, map_location='cpu', weights_only=True)\n\n\nstate = {k.replace('module.', ''): v for k, v in state.items()}\nmissing, unexpected = model.load_state_dict(state, strict=False)\nprint(f\"✓ Checkpoint loaded  |  missing: {len(missing)}  unexpected: {len(unexpected)}\")\n\nbackbone = model.feature_extractor.feature_extractor\nfor param in backbone.parameters():\n    param.requires_grad = False\nfor name, param in backbone.named_parameters():\n    if any(name.startswith(x) for x in ['Mixed_4e', 'Mixed_4f', 'Mixed_5b', 'Mixed_5c']):\n        param.requires_grad = True\n\nmodel = model.to(device)\n\nbackbone_params = [p for n, p in backbone.named_parameters() if p.requires_grad]\nhead_params = (list(model.transformer.transformer_encoder.parameters()) +\n               list(model.transformer.classifier.parameters()) +\n               list(model.transformer.pos_encoder.parameters()))\n\noptimizer = torch.optim.AdamW([\n    {'params': backbone_params, 'lr': LR_BACKBONE},\n    {'params': head_params,     'lr': LR_HEAD},\n], weight_decay=WEIGHT_DECAY)\nscheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=NUM_EPOCHS, eta_min=1e-6)  \ncriterion = nn.CrossEntropyLoss(label_smoothing=0.2)\nscaler    = torch.cuda.amp.GradScaler()   # ← mixed precision scaler\n\nprint(f\"Backbone params: {sum(p.numel() for p in backbone_params):,}\")\nprint(f\"Head params:     {sum(p.numel() for p in head_params):,}\")\n\ntrain_ds = WLASLDataset(VIDEO_DIR, NSLT_JSON, VALID_IDS, split='train',\n                         clip_len=CLIP_LEN, frame_size=FRAME_SIZE, augment=True)\nval_ds   = WLASLDataset(VIDEO_DIR, NSLT_JSON, VALID_IDS, split='val',\n                         clip_len=CLIP_LEN, frame_size=FRAME_SIZE, augment=False)\n\ntrain_loader = DataLoader(\n    train_ds, batch_size=BATCH_SIZE, shuffle=True,\n    num_workers=4,          # was 2\n    pin_memory=True,\n    prefetch_factor=2,      # pre-load 2 batches ahead per worker\n    persistent_workers=True # don't restart workers each epoch\n)\nval_loader   = DataLoader(val_ds,   batch_size=BATCH_SIZE, shuffle=False,\n                           num_workers=2, pin_memory=True)\nprint(f\"Train: {len(train_ds)}  Val: {len(val_ds)}\")\n\nimport time\n\ndef validate(model, loader):\n    model.eval()\n    c1 = c5 = total = 0\n    with torch.no_grad():\n        for clips, labels in loader:\n            clips, labels = clips.to(device), labels.to(device)\n            with torch.cuda.amp.autocast():\n                logits = model(clips)\n            c1 += (logits.argmax(1) == labels).sum().item()\n            _, top5 = logits.topk(5, 1)\n            c5 += sum(labels[i] in top5[i] for i in range(len(labels)))\n            total += len(labels)\n    return c1/total, c5/total\n\nbest_val = 0.54   # ← start from your known best so we only save improvements\nfor epoch in range(1, NUM_EPOCHS + 1):\n    model.train()\n    t0 = time.time()\n    loss_sum = correct = total = 0\n\n    for clips, labels in train_loader:\n        clips, labels = clips.to(device), labels.to(device)\n        optimizer.zero_grad()\n        with torch.amp.autocast(device_type='cuda'):          # ← fp16 forward pass\n            logits = model(clips)\n            loss   = criterion(logits, labels)\n        scaler.scale(loss).backward()\n        scaler.unscale_(optimizer)\n        nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n        scaler.step(optimizer)\n        scaler.update()\n\n        loss_sum += loss.item()\n        correct  += (logits.detach().argmax(1) == labels).sum().item()\n        total    += len(labels)\n\n    scheduler.step()\n    v1, v5 = validate(model, val_loader)\n    print(f\"Ep {epoch:2d}/{NUM_EPOCHS} ({time.time()-t0:.0f}s)  \"\n          f\"train={correct/total*100:.1f}%  val_top1={v1*100:.1f}%  val_top5={v5*100:.1f}%\")\n\n    if v1 > best_val:\n        best_val = v1\n        torch.save(model.state_dict(), f'{SAVE_DIR}/best_model_v2.pth')\n        print(f\"  ✓ New best: {v1*100:.2f}%  → best_model_v2.pth\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}